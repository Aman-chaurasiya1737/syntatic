/* ═══════════════════════════════════════════════════════════════════════════
   InterviewAI — Professional Dark Theme
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── CSS Variables ───────────────────────────────────────────────────────── */
:root {
    --bg-primary: #0a0e1a;
    --bg-secondary: #111827;
    --bg-card: #1a1f35;
    --bg-card-hover: #1f2544;
    --bg-input: #0f1424;
    --border-color: #2a3154;
    --border-focus: #3b82f6;

    --text-primary: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;

    --accent-blue: #3b82f6;
    --accent-purple: #8b5cf6;
    --accent-green: #22c55e;
    --accent-amber: #f59e0b;
    --accent-red: #ef4444;
    --accent-cyan: #06b6d4;

    --gradient-primary: linear-gradient(135deg, #3b82f6, #8b5cf6);
    --gradient-success: linear-gradient(135deg, #22c55e, #06b6d4);
    --gradient-danger: linear-gradient(135deg, #ef4444, #f59e0b);

    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --radius-xl: 24px;

    --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
    --shadow-glow: 0 0 30px rgba(59,130,246,0.15);

    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── Reset & Base ────────────────────────────────────────────────────────── */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: var(--font-sans);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
}

/* ── Views ───────────────────────────────────────────────────────────────── */
.view {
    display: none;
    min-height: 100vh;
    animation: fadeIn 0.4s ease;
}

.view.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ── Loading Overlay ─────────────────────────────────────────────────────── */
.loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 14, 26, 0.92);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: var(--transition);
}

.loading-overlay.hidden {
    opacity: 0;
    pointer-events: none;
}

.loader-content {
    text-align: center;
}

.spinner {
    width: 56px;
    height: 56px;
    border: 4px solid var(--border-color);
    border-top-color: var(--accent-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 20px;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loader-content p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    font-weight: 500;
}

/* ── Eye Warning Overlay ─────────────────────────────────────────────────── */
.eye-warning-overlay {
    position: fixed;
    inset: 0;
    background: rgba(239, 68, 68, 0.15);
    backdrop-filter: blur(2px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    transition: var(--transition);
    pointer-events: none;
}

.eye-warning-overlay.hidden {
    opacity: 0;
}

.warning-content {
    background: rgba(239, 68, 68, 0.95);
    color: white;
    padding: 24px 48px;
    border-radius: var(--radius-lg);
    text-align: center;
    animation: pulse 1s ease infinite;
}

.warning-content i {
    font-size: 2.5rem;
    margin-bottom: 10px;
    display: block;
}

.warning-content p {
    font-size: 1.3rem;
    font-weight: 600;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

/* ── Header ──────────────────────────────────────────────────────────────── */
.main-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 40px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
}

.logo i {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 1.8rem;
}

.logo .accent {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.tagline {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
}

/* ── Round Header ────────────────────────────────────────────────────────── */
.round-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 32px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
}

.round-header .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
}

.round-header .header-center {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 0 32px;
}

.logo-small {
    color: var(--text-primary);
    font-size: 1.1rem;
    font-weight: 700;
}

.logo-small i {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.round-badge {
    background: var(--gradient-primary);
    color: white;
    padding: 4px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
}

.results-badge {
    background: var(--gradient-success);
}

.interview-badge {
    background: linear-gradient(135deg, #8b5cf6, #ec4899);
}

.final-badge {
    background: linear-gradient(135deg, #f59e0b, #ef4444);
}

.timer {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--accent-amber);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    background: rgba(245, 158, 11, 0.1);
    padding: 6px 16px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(245, 158, 11, 0.3);
}

/* ── Question Progress ───────────────────────────────────────────────────── */
.question-progress {
    text-align: center;
    width: 100%;
    max-width: 300px;
}

.question-progress span {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
}

.progress-bar {
    width: 100%;
    height: 6px;
    background: var(--bg-input);
    border-radius: 3px;
    margin-top: 8px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: 3px;
    transition: width 0.5s ease;
}

/* ── Eye Status ──────────────────────────────────────────────────────────── */
.eye-status {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--accent-green);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 6px 16px;
    border-radius: var(--radius-md);
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
}

.eye-status.warning {
    color: var(--accent-red);
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.3);
}

/* ═══════════════════════════════════════════════════════════════════════════
   HOME PAGE
   ═══════════════════════════════════════════════════════════════════════════ */

.home-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    padding: 32px 40px;
    max-width: 1400px;
    margin: 0 auto;
    min-height: calc(100vh - 72px);
}

/* ── Setup Panel ─────────────────────────────────────────────────────────── */
.setup-panel, .history-panel {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow-md);
}

.panel-header {
    margin-bottom: 28px;
}

.panel-header h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.panel-header h2 i {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.panel-header p {
    color: var(--text-muted);
    font-size: 0.9rem;
}

/* ── Form ────────────────────────────────────────────────────────────────── */
.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.form-group label i {
    color: var(--accent-blue);
    width: 16px;
    text-align: center;
}

.form-group input,
.form-group select {
    width: 100%;
    padding: 12px 16px;
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: var(--transition);
    outline: none;
}

.form-group input::placeholder {
    color: var(--text-muted);
}

.form-group input:focus,
.form-group select:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

.form-group select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
}

/* ── File Upload ─────────────────────────────────────────────────────────── */
.file-upload-area {
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-md);
    padding: 24px;
    text-align: center;
    cursor: pointer;
    transition: var(--transition);
}

.file-upload-area:hover {
    border-color: var(--accent-blue);
    background: rgba(59, 130, 246, 0.05);
}

.upload-placeholder i {
    font-size: 2rem;
    color: var(--accent-blue);
    margin-bottom: 8px;
}

.upload-placeholder p {
    color: var(--text-secondary);
    font-weight: 500;
}

.upload-placeholder span {
    color: var(--text-muted);
    font-size: 0.8rem;
}

.upload-success {
    display: flex;
    align-items: center;
    gap: 12px;
}

.upload-success i {
    color: var(--accent-green);
    font-size: 1.3rem;
}

.upload-success p {
    color: var(--text-primary);
    font-weight: 500;
    flex: 1;
}

.hidden {
    display: none !important;
}

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
}

.btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
}

.btn:active {
    transform: translateY(0);
}

.btn-primary {
    background: var(--gradient-primary);
    color: white;
}

.btn-primary:hover {
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.4);
}

.btn-success {
    background: var(--gradient-success);
    color: white;
}

.btn-outline {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
}

.btn-outline:hover {
    border-color: var(--accent-blue);
    color: var(--accent-blue);
}

.btn-text {
    background: none;
    border: none;
    color: var(--accent-red);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 4px 8px;
    font-family: var(--font-sans);
}

.btn-sm {
    padding: 6px 12px;
    font-size: 0.85rem;
}

.btn-large {
    padding: 14px 32px;
    font-size: 1.05rem;
    width: 100%;
    justify-content: center;
}

.btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none !important;
}

/* ── History Panel ───────────────────────────────────────────────────────── */
.history-panel {
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 136px);
}

.avg-performance {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
}

.avg-card {
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px;
    text-align: center;
}

.avg-score {
    font-size: 1.5rem;
    font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.avg-label {
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 4px;
}

.history-list {
    flex: 1;
    overflow-y: auto;
    padding-right: 8px;
}

.history-list::-webkit-scrollbar {
    width: 6px;
}

.history-list::-webkit-scrollbar-track {
    background: transparent;
}

.history-list::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 3px;
}

.history-empty {
    text-align: center;
    padding: 48px 0;
    color: var(--text-muted);
}

.history-empty i {
    font-size: 3rem;
    margin-bottom: 12px;
    opacity: 0.3;
}

.history-empty p {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-secondary);
}

.history-empty span {
    font-size: 0.85rem;
}

.history-item {
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px;
    margin-bottom: 12px;
    transition: var(--transition);
}

.history-item:hover {
    border-color: var(--accent-blue);
    background: var(--bg-card-hover);
}

.history-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.history-item-name {
    font-weight: 600;
    color: var(--text-primary);
}

.history-item-date {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.history-item-details {
    display: flex;
    gap: 16px;
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.history-item-scores {
    display: flex;
    gap: 12px;
    margin-top: 8px;
}

.history-score-badge {
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
}

.score-good {
    background: rgba(34, 197, 94, 0.15);
    color: var(--accent-green);
}

.score-ok {
    background: rgba(245, 158, 11, 0.15);
    color: var(--accent-amber);
}

.score-low {
    background: rgba(239, 68, 68, 0.15);
    color: var(--accent-red);
}

/* ═══════════════════════════════════════════════════════════════════════════
   ROUND 1 — CODE EDITOR
   ═══════════════════════════════════════════════════════════════════════════ */

.round1-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: calc(100vh - 56px);
}

/* Question Panel */
.question-panel {
    padding: 24px;
    overflow-y: auto;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-color);
}

.question-header {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
}

.question-difficulty {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    background: rgba(245, 158, 11, 0.15);
    color: var(--accent-amber);
}

.question-topic {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    background: rgba(139, 92, 246, 0.15);
    color: var(--accent-purple);
}

.question-panel h2 {
    font-size: 1.4rem;
    margin-bottom: 16px;
    line-height: 1.4;
}

.question-body {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 24px;
    font-size: 0.95rem;
    white-space: pre-wrap;
}

.question-examples {
    margin-bottom: 24px;
}

.example-block {
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px;
    margin-bottom: 12px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
}

.example-block .example-label {
    color: var(--accent-blue);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 8px;
}

.example-block .example-io {
    color: var(--text-secondary);
    margin-bottom: 4px;
}

.example-block .example-io strong {
    color: var(--text-primary);
}

.example-block .example-explanation {
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    margin-top: 8px;
    font-style: italic;
}

.constraints-list {
    list-style: none;
}

.constraints-list li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding: 4px 0;
    padding-left: 16px;
    position: relative;
}

.constraints-list li::before {
    content: '•';
    color: var(--accent-blue);
    position: absolute;
    left: 0;
    font-weight: bold;
}

/* Editor Panel */
.editor-panel {
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
}

.editor-toolbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
}

.lang-select {
    padding: 6px 12px;
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    outline: none;
}

#code-editor {
    flex: 1;
}

.CodeMirror {
    height: 100% !important;
    font-family: var(--font-mono) !important;
    font-size: 14px !important;
}

.editor-footer {
    padding: 16px;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
}

/* ═══════════════════════════════════════════════════════════════════════════
   RESULTS PAGES
   ═══════════════════════════════════════════════════════════════════════════ */

.results-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 56px);
    padding: 32px;
}

.results-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 48px;
    max-width: 600px;
    width: 100%;
    text-align: center;
    box-shadow: var(--shadow-lg);
}

.results-card.wide-card {
    max-width: 800px;
}

.results-card.final-card {
    max-width: 900px;
    position: relative;
    overflow: hidden;
}

/* Score Circle */
.score-circle {
    position: relative;
    width: 140px;
    height: 140px;
    margin: 0 auto 24px;
}

.score-circle svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}

.score-bg {
    fill: none;
    stroke: var(--border-color);
    stroke-width: 8;
}

.score-fill {
    fill: none;
    stroke: url(#scoreGradient);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 339.292;
    stroke-dashoffset: 339.292;
    transition: stroke-dashoffset 1.5s ease;
}

.score-value {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    font-size: 2.5rem;
    font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.score-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, 60%);
    font-size: 1rem;
    color: var(--text-muted);
    font-weight: 600;
}

.results-card h2 {
    font-size: 1.3rem;
    margin-bottom: 24px;
    color: var(--text-primary);
}

/* Results Details */
.results-details {
    text-align: left;
    margin-bottom: 24px;
}

.detail-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 16px;
    border-radius: var(--radius-md);
    background: var(--bg-input);
    margin-bottom: 8px;
}

.detail-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.15);
    border-radius: var(--radius-sm);
    color: var(--accent-blue);
    flex-shrink: 0;
}

.detail-row strong {
    font-size: 0.85rem;
    color: var(--text-primary);
    display: block;
    margin-bottom: 2px;
}

.detail-row p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
}

/* Remarks Box */
.remarks-box {
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    margin-bottom: 24px;
    text-align: left;
    display: flex;
    gap: 12px;
    align-items: flex-start;
}

.remarks-box i {
    color: var(--accent-blue);
    font-size: 1.2rem;
    margin-top: 2px;
    flex-shrink: 0;
}

.remarks-box p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
}

/* Per-Question Results */
.per-question-results {
    margin-bottom: 24px;
}

.pq-item {
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px;
    margin-bottom: 10px;
    text-align: left;
}

.pq-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.pq-label {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
}

.pq-score {
    font-weight: 700;
    font-size: 0.9rem;
    padding: 2px 10px;
    border-radius: 12px;
}

.pq-question {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-bottom: 6px;
    font-style: italic;
}

.pq-remarks {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
}

/* ═══════════════════════════════════════════════════════════════════════════
   ROUND 2 — INTERVIEW
   ═══════════════════════════════════════════════════════════════════════════ */

.round2-container {
    display: grid;
    grid-template-columns: 380px 1fr;
    height: calc(100vh - 56px);
}

/* Video Panel */
.video-panel {
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    padding: 20px;
}

.video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    background: #000;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid var(--border-color);
}

.video-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scaleX(-1);
}

.video-wrapper canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
}

.video-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.7);
    color: var(--text-muted);
}

.video-overlay i {
    font-size: 2.5rem;
    margin-bottom: 10px;
}

.video-overlay.hidden {
    display: none;
}

.mic-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    margin-top: 16px;
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.mic-status i {
    color: var(--accent-green);
}

.mic-status.recording i {
    color: var(--accent-red);
    animation: blink 1s infinite;
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}

/* Interview Panel */
.interview-panel {
    display: flex;
    flex-direction: column;
    padding: 24px 32px;
    overflow-y: auto;
}

.interviewer-section {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-shrink: 0;
}

.interviewer-avatar {
    width: 50px;
    height: 50px;
    background: var(--gradient-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: white;
    flex-shrink: 0;
}

.interviewer-bubble {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 0 var(--radius-lg) var(--radius-lg) var(--radius-lg);
    padding: 20px;
    flex: 1;
}

.interviewer-name {
    font-weight: 700;
    color: var(--accent-blue);
    font-size: 0.85rem;
    margin-bottom: 8px;
}

.interviewer-bubble p {
    color: var(--text-primary);
    font-size: 1.05rem;
    line-height: 1.7;
}

/* Answer Section */
.answer-section {
    flex: 1;
    margin-bottom: 24px;
}

.answer-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.9rem;
}

.answer-header i {
    color: var(--accent-purple);
}

.recording-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--accent-red);
    font-size: 0.85rem;
    margin-left: auto;
}

.rec-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-red);
    border-radius: 50%;
    animation: blink 1s infinite;
}

.answer-text {
    background: var(--bg-input);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 20px;
    min-height: 200px;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-primary);
}

.answer-text .placeholder-text {
    color: var(--text-muted);
    font-style: italic;
}

/* Interview Controls */
.interview-controls {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
}

.interview-controls .btn {
    flex: 1;
}

/* ═══════════════════════════════════════════════════════════════════════════
   FINAL RESULTS
   ═══════════════════════════════════════════════════════════════════════════ */

.final-title {
    font-size: 2rem;
    font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 8px;
}

.final-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 40px;
}

.final-scores {
    display: flex;
    gap: 32px;
    justify-content: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
}

.final-score-card {
    text-align: center;
}

.final-score-card.total {
    border-left: 2px solid var(--border-color);
    padding-left: 32px;
}

.final-score-circle {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 12px;
}

.final-score-circle svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}

.final-score-circle .score-value {
    font-size: 2rem;
}

.final-score-card h3 {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 600;
}

/* ═══════════════════════════════════════════════════════════════════════════
   CONFETTI ANIMATION
   ═══════════════════════════════════════════════════════════════════════════ */

.confetti-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 200px;
    overflow: hidden;
    pointer-events: none;
}

.confetti-piece {
    position: absolute;
    width: 10px;
    height: 10px;
    top: -10px;
    animation: confettiFall 3s ease-out forwards;
}

@keyframes confettiFall {
    0% { transform: translateY(0) rotate(0deg); opacity: 1; }
    100% { transform: translateY(400px) rotate(720deg); opacity: 0; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   SVG GRADIENT (for score circles)
   ═══════════════════════════════════════════════════════════════════════════ */

/* We define this inline since SVG gradients need to be in in the DOM */

/* ═══════════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 1024px) {
    .home-container {
        grid-template-columns: 1fr;
        padding: 20px;
    }

    .round1-container {
        grid-template-columns: 1fr;
        height: auto;
    }

    .question-panel {
        max-height: 40vh;
        overflow-y: auto;
        border-right: none;
        border-bottom: 1px solid var(--border-color);
    }

    .editor-panel {
        min-height: 60vh;
    }

    .round2-container {
        grid-template-columns: 1fr;
        height: auto;
    }

    .video-panel {
        border-right: none;
        border-bottom: 1px solid var(--border-color);
    }

    .final-scores {
        flex-direction: column;
        align-items: center;
    }

    .final-score-card.total {
        border-left: none;
        border-top: 2px solid var(--border-color);
        padding-left: 0;
        padding-top: 32px;
    }
}

@media (max-width: 640px) {
    .main-header {
        padding: 12px 16px;
    }

    .home-container {
        padding: 16px;
    }

    .setup-panel, .history-panel {
        padding: 20px;
    }

    .avg-performance {
        grid-template-columns: repeat(2, 1fr);
    }

    .interview-controls {
        flex-direction: column;
    }
}
